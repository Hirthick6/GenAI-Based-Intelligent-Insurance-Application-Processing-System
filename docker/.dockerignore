# Docker ignore file - excludes unnecessary files from build context

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.coverage
htmlcov/

# Virtual environments
venv/
env/
ENV/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Environment
.env
.env.local

# Documentation
*.md
!README.md

# Docker
docker/
Dockerfile
docker-compose*.yml

# Data directories (will be mounted as volumes)
uploads/
processed/
*.db
*.sqlite

# Logs
*.log
logs/
