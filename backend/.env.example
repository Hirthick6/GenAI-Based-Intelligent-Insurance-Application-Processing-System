# PostgreSQL Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tce_project
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tce_project
DB_USER=postgres
DB_PASSWORD=postgres

# Email IMAP Configuration
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_EMAIL=your-email@gmail.com
IMAP_PASSWORD=your-app-password
IMAP_FOLDER=INBOX

# GenAI Configuration (Groq)
GROQ_API_KEY=your-groq-api-key
GENAI_PROVIDER=groq

# Tesseract Path (Windows)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# File Storage (paths relative to backend root; use "uploads" and "processed" for default)
UPLOAD_DIR=uploads
PROCESSED_DIR=processed

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Auth (JWT)
JWT_SECRET=your-super-secret-key-change-in-production
