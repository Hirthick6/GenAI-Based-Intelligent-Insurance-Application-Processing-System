# PostgreSQL Database
DATABASE_URL=postgresql://postgres:root@localhost:5433/tce_project
DB_HOST=localhost
DB_PORT=5433
DB_NAME=tce_project
DB_USER=postgres
DB_PASSWORD=<your-db-password>

# Email IMAP Configuration
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_EMAIL=<your-imap-email>
IMAP_PASSWORD=<your-imap-password>
IMAP_FOLDER=INBOX

# GenAI Configuration
GROQ_API_KEY=<your-groq-api-key>
GENAI_PROVIDER=groq

# Tesseract Path (Windows)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# File Storage
UPLOAD_DIR=./uploads
PROCESSED_DIR=./processed

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=True
