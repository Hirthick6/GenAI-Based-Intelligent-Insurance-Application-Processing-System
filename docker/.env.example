# Docker Environment Configuration for TCE Insurance Document Processor
# Copy this file to .env and update with your actual values

# ============================================
# Database Configuration
# ============================================
DB_NAME=tce_project
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# ============================================
# Email IMAP Configuration
# ============================================
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_EMAIL=your-email@gmail.com
IMAP_PASSWORD=your-app-password
IMAP_FOLDER=INBOX

# ============================================
# GenAI Configuration (Groq)
# ============================================
GROQ_API_KEY=your-groq-api-key-here
GENAI_PROVIDER=groq

# ============================================
# Server Ports
# ============================================
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ============================================
# Application Settings
# ============================================
DEBUG=false

# ============================================
# Security (IMPORTANT: Change in production!)
# ============================================
JWT_SECRET=your-super-secret-key-change-in-production-use-long-random-string
