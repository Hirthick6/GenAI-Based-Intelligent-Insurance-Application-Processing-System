# Docker Environment Configuration for TCE Insurance Document Processor
# Configured for your application

# ============================================
# Database Configuration
# ============================================
DB_NAME=tce_project
DB_USER=postgres
DB_PASSWORD=<your-db-password>
DB_PORT=5432

# ============================================
# Email IMAP Configuration
# ============================================
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_EMAIL=<your-imap-email>
IMAP_PASSWORD=<your-imap-password>
IMAP_FOLDER=INBOX

# ============================================
# GenAI Configuration (Groq)
# ============================================
GROQ_API_KEY=<your-groq-api-key>
GENAI_PROVIDER=groq

# ============================================
# Server Ports
# ============================================
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ============================================
# Application Settings
# ============================================
DEBUG=false

# ============================================
# Security (JWT Token Secret)
# ============================================
JWT_SECRET=<your-jwt-secret>
